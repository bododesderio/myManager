generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════

enum UserStatus {
  PENDING_PAYMENT
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum WorkspaceAccountType {
  INDIVIDUAL
  COMPANY
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum MemberStatus {
  ACTIVE
  SOFT_LOCKED
  REMOVED
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  GRACE_PERIOD
  CANCELLING
  CANCELLED
  SUPERSEDED
  PENDING_PAYMENT
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REVISION_REQUESTED
  PENDING_CLIENT_APPROVAL
  APPROVED_BY_CLIENT
  SCHEDULED
  QUEUED
  PUBLISHING
  PUBLISHED
  PARTIALLY_PUBLISHED
  FAILED
  CANCELLED
  DELETED
}

enum CmsFieldType {
  TEXT
  TEXTAREA
  RICHTEXT
  URL
  IMAGE_URL
  COLOR
  BOOLEAN
  NUMBER
  JSON
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED_WON
  CLOSED_LOST
}

enum ThemeMode {
  LIGHT
  DARK
  OS
  USER
}

// ═══════════════════════════════════════════════════════════
// CORE IDENTITY & AUTH
// ═══════════════════════════════════════════════════════════

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  name              String
  first_name        String     @default("")
  last_name         String     @default("")
  password_hash     String?
  avatar_url        String?
  email_verified    Boolean    @default(false)
  is_superadmin     Boolean    @default(false)
  is_suspended      Boolean    @default(false)
  status            UserStatus @default(PENDING_VERIFICATION)
  last_workspace_id String?
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  preferences              UserPreferences?
  push_tokens              UserPushToken[]
  totp_backup_codes        TotpBackupCode[]
  sessions                 Session[]
  accounts                 Account[]
  workspace_members        WorkspaceMember[]
  project_members          ProjectMember[]
  posts                    Post[]
  notifications            Notification[]
  notification_prefs       NotificationPreference[]
  ai_credit_usage          AiCreditUsage[]
  audit_logs               AuditLog[]
  subscriptions            Subscription[]
  plan_overrides_received  PlanOverride[]          @relation("OverrideUser")
  plan_overrides_given     PlanOverride[]          @relation("OverrideAdmin")
  comment_assignments      CommentAssignment[]     @relation("AssignedTo")
  comment_assignments_by   CommentAssignment[]     @relation("AssignedBy")
  data_export_requests     DataExportRequest[]
  deletion_requests        DeletionRequest[]
  cookie_consents          CookieConsent[]
  email_preferences        UserEmailPreference[]
  password_reset_tokens    PasswordResetToken[]
  email_verification_tokens EmailVerificationToken[]
  workspace_invitations    WorkspaceInvitation[]
  refresh_tokens           RefreshToken[]
  blog_posts               BlogPost[]
  owned_workspaces         Workspace[]             @relation("WorkspaceOwner")
  portal_tokens_created    PortalAccessToken[]     @relation("PortalTokenCreator")
  post_comments            PostComment[]
  approval_events          ApprovalEvent[]
  comment_replies          SocialComment[]          @relation("CommentReplies")

  @@index([email])
  @@map("users")
}

model UserPreferences {
  id                  String   @id @default(uuid())
  user_id             String   @unique
  language            String   @default("en")
  currency            String   @default("USD")
  timezone            String   @default("Africa/Kampala")
  theme               String   @default("system")
  theme_preference    String?
  totp_enabled        Boolean  @default(false)
  totp_secret         String?
  lang_source         String   @default("default")
  notifications_email Boolean  @default(true)
  notifications_push  Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserPushToken {
  id          String   @id @default(uuid())
  user_id     String
  token       String
  platform    String
  device_name String?
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, token])
  @@map("user_push_tokens")
}

model TotpBackupCode {
  id         String    @id @default(uuid())
  user_id    String
  code_hash  String
  used       Boolean   @default(false)
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("totp_backup_codes")
}

model Session {
  id            String   @id @default(uuid())
  session_token String   @unique
  user_id       String
  expires       DateTime
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                  String   @id @default(uuid())
  user_id             String
  type                String
  provider            String
  provider_account_id String
  refresh_token       String?
  access_token        String?
  expires_at          Int?
  token_type          String?
  scope               String?
  id_token            String?
  session_state       String?
  created_at          DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_account_id])
  @@map("accounts")
}

// ═══════════════════════════════════════════════════════════
// AUTH TOKENS
// ═══════════════════════════════════════════════════════════

model RefreshToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  revoked_at DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@index([user_id])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@index([user_id])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@index([user_id])
  @@map("email_verification_tokens")
}

// ═══════════════════════════════════════════════════════════
// PLANS & BILLING
// ═══════════════════════════════════════════════════════════

model Plan {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique
  description       String   @default("")
  price_monthly_usd Decimal  @default(0) @db.Decimal(10, 2)
  price_annual_usd  Decimal  @default(0) @db.Decimal(10, 2)
  seat_price_usd    Float    @default(0)
  limits            Json
  features          Json
  is_active         Boolean  @default(true)
  is_custom         Boolean  @default(false)
  sort_order        Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  subscriptions  Subscription[]
  plan_overrides PlanOverride[]

  @@map("plans")
}

model Subscription {
  id                          String       @id @default(uuid())
  user_id                     String
  workspace_id                String       @unique
  plan_id                     String
  flutterwave_subscription_id String?
  status                      SubStatus    @default(ACTIVE)
  billing_cycle               BillingCycle @default(MONTHLY)
  billing_currency            String       @default("USD")
  billing_amount              Float        @default(0)
  locked_limits               Json
  locked_features             Json
  current_period_start        DateTime
  current_period_end          DateTime
  grace_period_ends_at        DateTime?
  extra_seats                 Int          @default(0)
  cancel_at_period_end        Boolean      @default(false)
  created_at                  DateTime     @default(now())
  updated_at                  DateTime     @updatedAt

  user               User               @relation(fields: [user_id], references: [id])
  workspace          Workspace          @relation(fields: [workspace_id], references: [id])
  plan               Plan               @relation(fields: [plan_id], references: [id])
  subscription_items SubscriptionItem[]

  @@map("subscriptions")
}

model SubscriptionItem {
  id              String   @id @default(uuid())
  subscription_id String
  type            String
  quantity        Int      @default(1)
  unit_price      Float
  created_at      DateTime @default(now())

  subscription Subscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@map("subscription_items")
}

model BillingHistory {
  id              String   @id @default(uuid())
  workspace_id    String
  user_id         String
  plan_name       String
  amount          Float
  currency        String
  status          String
  flutterwave_ref String?
  invoice_url     String?
  billing_period  String?
  created_at      DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id])

  @@index([workspace_id, created_at])
  @@index([user_id, created_at])
  @@index([flutterwave_ref])
  @@map("billing_history")
}

model PlanOverride {
  id             String    @id @default(uuid())
  user_id        String
  plan_id        String
  admin_id       String
  reason         String
  override_until DateTime?
  created_at     DateTime  @default(now())

  user  User @relation("OverrideUser", fields: [user_id], references: [id])
  admin User @relation("OverrideAdmin", fields: [admin_id], references: [id])
  plan  Plan @relation(fields: [plan_id], references: [id])

  @@map("plan_overrides")
}

model SalesLead {
  id           String   @id @default(uuid())
  name         String
  email        String
  company      String?
  message      String
  source       String   @default("contact_form")
  status       String   @default("new")
  responded_at DateTime?
  created_at   DateTime @default(now())

  @@map("sales_leads")
}

// ═══════════════════════════════════════════════════════════
// WORKSPACES & TEAMS
// ═══════════════════════════════════════════════════════════

model Workspace {
  id              String               @id @default(uuid())
  name            String
  slug            String               @unique
  description     String?
  owner_id        String?
  account_type    WorkspaceAccountType @default(INDIVIDUAL)
  industry        String?
  team_size       String?
  referral_source String?
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt

  owner               User?                    @relation("WorkspaceOwner", fields: [owner_id], references: [id])
  members             WorkspaceMember[]
  projects            Project[]
  social_accounts     SocialAccount[]
  posts               Post[]
  subscriptions       Subscription[]
  billing_history     BillingHistory[]
  media_assets        MediaAsset[]
  campaigns           Campaign[]
  notifications       Notification[]
  approval_config     WorkspaceApprovalConfig?
  brand_config        WorkspaceBrandConfig?
  analytics_daily     WorkspaceAnalyticsDaily[]
  best_times          BestTime[]
  hashtag_sets        HashtagSet[]
  hashtags            Hashtag[]
  reports             Report[]
  report_configs      ReportConfig[]
  utm_configs         UtmConfig[]
  bio_pages           BioPage[]
  rss_feeds           RssFeed[]
  listening_terms     ListeningTerm[]
  competitor_profiles CompetitorProfile[]
  webhook_endpoints   WebhookEndpoint[]
  api_keys            ApiKey[]
  whatsapp_lists      WhatsAppContactList[]
  post_templates      PostTemplate[]
  invitations         WorkspaceInvitation[]

  @@index([owner_id])
  @@map("workspaces")
}

model WorkspaceMember {
  id             String       @id @default(uuid())
  user_id        String
  workspace_id   String
  role           WorkspaceRole @default(MEMBER)
  status         MemberStatus  @default(ACTIVE)
  invited_by_id  String?
  joined_at      DateTime     @default(now())
  last_active_at DateTime?

  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([user_id, workspace_id])
  @@index([workspace_id, role])
  @@index([user_id, workspace_id])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id            String        @id @default(uuid())
  workspace_id  String
  email         String
  role          WorkspaceRole @default(MEMBER)
  token         String
  invited_by_id String
  expires_at    DateTime
  accepted_at   DateTime?
  cancelled_at  DateTime?
  created_at    DateTime      @default(now())

  workspace  Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  invited_by User      @relation(fields: [invited_by_id], references: [id])

  @@index([workspace_id, email])
  @@index([token])
  @@map("workspace_invitations")
}

model WorkspaceApprovalConfig {
  id                    String   @id @default(uuid())
  workspace_id          String   @unique
  require_approval      Boolean  @default(false)
  auto_approve_admins   Boolean  @default(true)
  require_client_review Boolean  @default(false)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("workspace_approval_configs")
}

model WorkspaceBrandConfig {
  id           String   @id @default(uuid())
  workspace_id String   @unique
  config       Json
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("workspace_brand_configs")
}

// ═══════════════════════════════════════════════════════════
// PROJECTS (Enterprise)
// ═══════════════════════════════════════════════════════════

model Project {
  id                  String   @id @default(uuid())
  workspace_id        String
  name                String
  slug                String
  description         String?
  client_name         String?
  client_email        String?
  monthly_post_target Int      @default(0)
  status              String   @default("active")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  workspace      Workspace          @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  members        ProjectMember[]
  brand_config   ProjectBrandConfig?
  portal_tokens  PortalAccessToken[]
  portal_actions PortalAction[]
  posts          Post[]

  @@unique([workspace_id, slug])
  @@index([workspace_id, created_at])
  @@index([workspace_id, status])
  @@map("projects")
}

model ProjectMember {
  id          String   @id @default(uuid())
  project_id  String
  user_id     String
  role        String   @default("contributor")
  assigned_at DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@map("project_members")
}

model ProjectBrandConfig {
  id         String   @id @default(uuid())
  project_id String   @unique
  config     Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_brand_configs")
}

model PortalAccessToken {
  id            String    @id @default(uuid())
  project_id    String
  token         String    @unique
  token_hash    String?
  label         String
  client_email  String?
  client_name   String?
  created_by_id String?
  expires_at    DateTime?
  revoked_at    DateTime?
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())

  project    Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  created_by User?         @relation("PortalTokenCreator", fields: [created_by_id], references: [id])
  actions    PortalAction[]
  audit_logs PortalAuditLog[]

  @@index([project_id])
  @@index([token_hash])
  @@map("portal_access_tokens")
}

model PortalAction {
  id              String   @id @default(uuid())
  portal_token_id String
  project_id      String
  action          String
  metadata        Json     @default("{}")
  ip_address      String?
  created_at      DateTime @default(now())

  portal_token PortalAccessToken @relation(fields: [portal_token_id], references: [id])
  project      Project           @relation(fields: [project_id], references: [id])

  @@map("portal_actions")
}

model PortalAuditLog {
  id              String   @id @default(uuid())
  portal_token_id String
  action          String
  post_id         String?
  comment         String?
  ip_address      String?
  user_agent      String?
  created_at      DateTime @default(now())

  portal_token PortalAccessToken @relation(fields: [portal_token_id], references: [id])

  @@map("portal_audit_logs")
}

// ═══════════════════════════════════════════════════════════
// PLATFORMS
// ═══════════════════════════════════════════════════════════

model Platform {
  id                     String   @id @default(uuid())
  slug                   String   @unique
  name                   String   @default("")
  display_name           String
  color                  String   @default("#111111")
  api_version            String
  auth_type              String
  phase                  Int      @default(1)
  max_caption_chars      Int
  max_images             Int
  max_file_size_mb       Int
  max_video_duration_sec Int
  min_image_width        Int
  min_image_height       Int
  content_types          Json     @default("[]")
  limits                 Json     @default("{}")
  is_active              Boolean  @default(true)
  created_at             DateTime @default(now())

  platform_content_types PlatformContentType[]
  social_accounts        SocialAccount[]
  board_cache            PlatformBoardCache[]

  @@map("platforms")
}

model ContentTypeModel {
  id             String   @id @default(uuid())
  slug           String   @unique
  display_name   String
  requires_media Boolean  @default(false)
  created_at     DateTime @default(now())

  platform_content_types PlatformContentType[]

  @@map("content_types")
}

model PlatformContentType {
  id              String @id @default(uuid())
  platform_id     String
  content_type_id String

  platform     Platform         @relation(fields: [platform_id], references: [id])
  content_type ContentTypeModel @relation(fields: [content_type_id], references: [id])

  @@unique([platform_id, content_type_id])
  @@map("platform_content_types")
}

model SocialAccount {
  id                      String    @id @default(uuid())
  workspace_id            String
  platform_id             String
  platform_user_id        String
  platform_username       String
  display_name            String
  avatar_url              String?
  access_token_encrypted  String
  refresh_token_encrypted String?
  token_expires_at        DateTime?
  scopes                  String[]
  metadata                Json      @default("{}")
  is_active               Boolean   @default(true)
  connected_at            DateTime  @default(now())
  last_used_at            DateTime?

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  platform  Platform  @relation(fields: [platform_id], references: [id])

  @@unique([workspace_id, platform_id, platform_user_id])
  @@map("social_accounts")
}

model PlatformBoardCache {
  id           String   @id @default(uuid())
  platform_id  String
  workspace_id String
  board_id     String
  board_name   String
  cached_at    DateTime @default(now())

  platform Platform @relation(fields: [platform_id], references: [id])

  @@map("platform_board_cache")
}

model WhatsAppContactList {
  id            String   @id @default(uuid())
  workspace_id  String
  name          String
  description   String?
  contact_count Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("whatsapp_contact_lists")
}

// ═══════════════════════════════════════════════════════════
// POSTS & CONTENT
// ═══════════════════════════════════════════════════════════

model Post {
  id                    String     @id @default(uuid())
  workspace_id          String
  project_id            String?
  campaign_id           String?
  user_id               String
  caption               String     @db.Text
  content_type          String
  platforms             String[]
  status                PostStatus @default(DRAFT)
  scheduled_at          DateTime?
  published_at          DateTime?
  link_url              String?
  link_preview_override Json?
  first_comment_text    String?
  failure_reason        String?
  platform_options      Json       @default("{}")
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  user             User                @relation(fields: [user_id], references: [id])
  workspace        Workspace           @relation(fields: [workspace_id], references: [id])
  project          Project?            @relation(fields: [project_id], references: [id])
  campaign         Campaign?           @relation(fields: [campaign_id], references: [id])
  platform_results PostPlatformResult[]
  versions         PostVersion[]
  media            PostMedia[]
  post_hashtags    PostHashtag[]
  analytics        PostAnalytics[]
  post_comments    PostComment[]
  approval_events  ApprovalEvent[]
  recurrence_plan  RecurrencePlan?
  campaign_posts   CampaignPost[]

  @@index([workspace_id, status])
  @@index([scheduled_at])
  @@index([workspace_id, scheduled_at])
  @@index([workspace_id, published_at])
  @@index([project_id, status])
  @@map("posts")
}

model PostPlatformResult {
  id                String    @id @default(uuid())
  post_id           String
  platform          String
  status            String    @default("pending")
  platform_post_id  String?
  platform_post_url String?
  error_message     String?
  published_at      DateTime?

  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([post_id, platform])
  @@map("post_platform_results")
}

model PostVersion {
  id         String   @id @default(uuid())
  post_id    String
  version    Int
  caption    String
  media_ids  String[]
  metadata   Json     @default("{}")
  created_at DateTime @default(now())

  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@map("post_versions")
}

model PostMedia {
  id             String @id @default(uuid())
  post_id        String
  media_asset_id String
  sort_order     Int    @default(0)

  post        Post       @relation(fields: [post_id], references: [id], onDelete: Cascade)
  media_asset MediaAsset @relation(fields: [media_asset_id], references: [id])

  @@unique([post_id, media_asset_id])
  @@map("post_media")
}

model Hashtag {
  id           String   @id @default(uuid())
  text         String
  workspace_id String
  platform     String?
  created_at   DateTime @default(now())

  workspace     Workspace     @relation(fields: [workspace_id], references: [id])
  post_hashtags PostHashtag[]

  @@unique([workspace_id, text, platform])
  @@map("hashtags")
}

model PostHashtag {
  id         String @id @default(uuid())
  post_id    String
  hashtag_id String

  post    Post    @relation(fields: [post_id], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtag_id], references: [id])

  @@unique([post_id, hashtag_id])
  @@map("post_hashtags")
}

model PostTemplate {
  id           String   @id @default(uuid())
  workspace_id String
  name         String
  caption      String
  content_type String?
  platforms    String[]
  media_urls   String[]
  metadata     Json     @default("{}")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("post_templates")
}

model RecurrencePlan {
  id           String    @id @default(uuid())
  post_id      String    @unique
  frequency    String
  interval     Int       @default(1)
  day_of_week  Int?
  day_of_month Int?
  ends_at      DateTime?
  next_run_at  DateTime?
