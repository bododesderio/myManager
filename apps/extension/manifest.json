{
  "manifest_version": 3,
  "name": "myManager",
  "version": "0.1.0",
  "description": "Quick capture: save any page or selected text as a draft post in your myManager workspace.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to myManager"
  },
  "permissions": ["activeTab", "storage", "contextMenus"],
  "host_permissions": [
    "https://*.mymanager.app/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
