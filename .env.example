# Database
DATABASE_URL=                          # PostgreSQL connection string

# Redis
REDIS_URL=                             # Redis connection string

# Auth
JWT_SECRET=                            # Random secret for API JWT tokens (min 32 chars)
NEXTAUTH_SECRET=                       # Random secret for NextAuth.js session encryption
NEXTAUTH_URL=                          # Full URL of the web app (e.g. https://app.mymanager.com)
AUTH_SECRET=                            # Alias for NEXTAUTH_SECRET (fallback)

# App URLs
NEXT_PUBLIC_APP_URL=                   # Public-facing app URL (e.g. https://mymanager.app)
NEXT_PUBLIC_API_URL=                   # Public API URL exposed to browser (e.g. https://api.mymanager.app)
API_URL=                               # Internal API URL for server-side calls (e.g. http://localhost:3001)
WEB_URL=                               # Web app origin used by API for CORS / emails (e.g. https://mymanager.app)
PORT=                                  # API server port (default: 3001)

# Branding
BRAND_NAME=                            # App brand name used in emails (default: MyManager)
EMAIL_DOMAIN=                          # Domain used in email From header (default: mymanager.com)

# Social OAuth credentials
# Facebook + Instagram + WhatsApp + Threads: one Meta app, multiple permissions
FACEBOOK_APP_ID=                       # Meta App ID
FACEBOOK_APP_SECRET=                   # Meta App Secret
# Instagram uses the same FACEBOOK_APP_ID / FACEBOOK_APP_SECRET
# WhatsApp Business (additional Meta Business credentials)
WHATSAPP_SYSTEM_USER_TOKEN=            # permanent system user token from Meta Business Manager
WHATSAPP_PHONE_NUMBER_ID=             # WhatsApp Business phone number ID
WHATSAPP_WABA_ID=                     # WhatsApp Business Account ID
# Threads uses the same FACEBOOK_APP_ID / FACEBOOK_APP_SECRET + additional scopes

# X / Twitter
TWITTER_CLIENT_ID=                     # Twitter OAuth 2.0 Client ID
TWITTER_CLIENT_SECRET=                 # Twitter OAuth 2.0 Client Secret

# LinkedIn
LINKEDIN_CLIENT_ID=                    # LinkedIn OAuth 2.0 Client ID
LINKEDIN_CLIENT_SECRET=                # LinkedIn OAuth 2.0 Client Secret

# TikTok
TIKTOK_CLIENT_KEY=                     # TikTok app Client Key
TIKTOK_CLIENT_SECRET=                  # TikTok app Client Secret

# Google (used for: Google Sign-In + Google Business Profile + YouTube — one OAuth app)
GOOGLE_CLIENT_ID=                      # Google OAuth 2.0 Client ID
GOOGLE_CLIENT_SECRET=                  # Google OAuth 2.0 Client Secret

# Pinterest
PINTEREST_APP_ID=                      # Pinterest App ID
PINTEREST_APP_SECRET=                  # Pinterest App Secret

# Payments
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=    # Flutterwave public key (exposed to browser for inline checkout)
FLUTTERWAVE_SECRET_KEY=                # Flutterwave secret key (server-only)
FLUTTERWAVE_WEBHOOK_SECRET=            # Flutterwave secret hash for webhook signature verification

# Webhooks
WEBHOOK_VERIFY_TOKEN=                  # Token for verifying social platform webhook subscriptions
WEBHOOK_FORWARD_SECRET=                # Shared secret used by the web app to forward verified webhooks to the API

# Storage
STORAGE_DRIVER=                        # 'local' or 'r2' (default: local)
LOCAL_STORAGE_PATH=                    # Local upload path (default: ./uploads)
CLOUDFLARE_R2_ACCOUNT_ID=             # Cloudflare account ID
CLOUDFLARE_R2_ACCESS_KEY=             # R2 access key ID
CLOUDFLARE_R2_SECRET_KEY=             # R2 secret access key
CLOUDFLARE_R2_BUCKET=                 # R2 bucket name
CLOUDFLARE_R2_PUBLIC_URL=             # Public URL for R2 bucket (via custom domain or r2.dev)

# Email
RESEND_API_KEY=                        # Resend API key for transactional emails

# AI
ANTHROPIC_API_KEY=                     # Claude API (captions, image analysis, content insights)
REPLICATE_API_KEY=                     # Stable Diffusion (AI image generation)
OPENAI_API_KEY=                        # Whisper only (video auto-captions)

# Self-hosted tools
LANGUAGETOOL_URL=                      # OPTIONAL — e.g. http://languagetool:8010. Leave empty to disable grammar checks (no error).

# Analytics & monitoring
GOOGLE_ANALYTICS_PROPERTY_ID=         # optional — for deep GA4 integration
POSTHOG_API_KEY=                       # PostHog product analytics
SENTRY_DSN=                            # runtime error tracking (all apps)
SENTRY_AUTH_TOKEN=                     # CI only — for source map uploads to Sentry

# Token encryption (NEVER commit this value)
ENCRYPTION_KEY=                        # 32-byte hex key for AES-256 OAuth token encryption

# Exchange rates
OPEN_EXCHANGE_RATES_API_KEY=          # Open Exchange Rates API key

# Mobile (CI/CD secret — not a runtime secret)
EXPO_TOKEN=                            # EAS CLI authentication in GitHub Actions

# Deployment (CI/CD secrets only — not runtime)
RAILWAY_TOKEN=                         # Railway CLI authentication in GitHub Actions
VERCEL_TOKEN=                          # Vercel CLI authentication in GitHub Actions
VERCEL_ORG_ID=                         # Vercel organization ID
VERCEL_PROJECT_ID=                     # Vercel project ID
DOCKER_REGISTRY=                       # container registry URL for worker images
DOCKER_USERNAME=                       # container registry username
DOCKER_PASSWORD=                       # container registry password

# Security
# Apple Sign-In OAuth (apple.strategy.ts)
APPLE_CLIENT_ID=                       # Apple Services ID (e.g. com.yourapp.web)
APPLE_TEAM_ID=                         # Apple Developer Team ID (10 chars)
APPLE_KEY_ID=                          # Apple Sign-In Key ID
APPLE_PRIVATE_KEY=                     # Apple Sign-In private key (PEM, escaped newlines)

METRICS_TOKEN=                         # required to access /metrics (random 32+ bytes hex)
OAUTH_REDIRECT_WHITELIST=http://localhost:3000/auth/google/callback   # comma-separated allowed Google OAuth redirect URIs
ENABLE_SWAGGER=                        # set to "true" to expose /api/docs in production
DEMO_USER_PASSWORD=                    # required by prisma/seeds/demo.seed.ts (dev only)
