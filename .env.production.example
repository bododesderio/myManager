# ═══════════════════════════════════════════════════════════════════════════════
# myManager — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file and fill in real values for your production deployment.
# NEVER commit the filled-in version to version control.
#
# Legend:
#   [REQUIRED]  — the app will not start or will malfunction without this
#   [OPTIONAL]  — feature-gated; the app works without it but the feature is disabled
#   [CI-ONLY]   — only needed in CI/CD pipelines, not at runtime
#
# Railway env var names shown where they differ (e.g. ${{Postgres.DATABASE_URL}}).
# Vercel env var names shown where applicable.
# ═══════════════════════════════════════════════════════════════════════════════


# ─── Database ─────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string.
# Railway: use the reference variable ${{Postgres.DATABASE_URL}} from the Postgres plugin.
# Must include ?sslmode=require for production.
DATABASE_URL=postgresql://user:password@host:5432/mymanager?sslmode=require


# ─── Redis ────────────────────────────────────────────────────────────────────
# [REQUIRED] Redis connection string for BullMQ queues, caching, and distributed locks.
# Railway: use the reference variable ${{Redis.REDIS_URL}} from the Redis plugin.
REDIS_URL=redis://default:password@host:6379


# ─── Authentication & Session Secrets ─────────────────────────────────────────
# [REQUIRED] Secret for signing API JWT tokens. Must be at least 32 characters.
# Generate with: openssl rand -base64 48
JWT_SECRET=

# [REQUIRED] Secret for NextAuth.js session encryption. Must be at least 32 characters.
# Generate with: openssl rand -base64 48
NEXTAUTH_SECRET=

# [REQUIRED] Full canonical URL of the web app (used by NextAuth for callbacks).
# Vercel: set NEXTAUTH_URL to your production domain, e.g. https://app.mymanager.com
NEXTAUTH_URL=https://app.mymanager.com

# [OPTIONAL] Alias/fallback for NEXTAUTH_SECRET. Set to the same value.
AUTH_SECRET=


# ─── Token Encryption ────────────────────────────────────────────────────────
# [REQUIRED] 32-byte hex key for AES-256 encryption of stored OAuth tokens.
# Generate with: openssl rand -hex 32
# NEVER lose this key — you cannot decrypt stored tokens without it.
ENCRYPTION_KEY=


# ─── App URLs ─────────────────────────────────────────────────────────────────
# [REQUIRED] Public-facing web app URL (shown to users, used in emails).
# Vercel: automatically set via VERCEL_URL, but override with your custom domain.
NEXT_PUBLIC_APP_URL=https://app.mymanager.com

# [REQUIRED] Public API URL exposed to the browser (fetch calls from Next.js client).
NEXT_PUBLIC_API_URL=https://api.mymanager.com

# [REQUIRED] Internal API URL for server-side calls (SSR, server components).
# Railway: use the private networking URL, e.g. http://api.railway.internal:3001
API_URL=http://api.railway.internal:3001

# [REQUIRED] Web app origin used by the API for CORS headers and email links.
WEB_URL=https://app.mymanager.com

# [OPTIONAL] API server port. Railway assigns $PORT automatically; default 3001.
# Railway: do NOT set this — Railway injects PORT automatically.
# PORT=3001


# ─── Branding ─────────────────────────────────────────────────────────────────
# [OPTIONAL] App brand name used in transactional emails (default: MyManager).
BRAND_NAME=MyManager

# [OPTIONAL] Domain used in email From header (default: mymanager.com).
EMAIL_DOMAIN=mymanager.com


# ─── Social OAuth Credentials ─────────────────────────────────────────────────
# Each platform requires its own OAuth app. Set only the platforms you use.

# Facebook + Instagram + WhatsApp + Threads (one Meta App)
# [OPTIONAL] Meta App ID and Secret — enables Facebook, Instagram, Threads publishing.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# WhatsApp Business (additional Meta Business credentials)
# [OPTIONAL] Permanent system user token from Meta Business Manager.
WHATSAPP_SYSTEM_USER_TOKEN=
# [OPTIONAL] WhatsApp Business phone number ID.
WHATSAPP_PHONE_NUMBER_ID=
# [OPTIONAL] WhatsApp Business Account ID.
WHATSAPP_WABA_ID=

# X / Twitter
# [OPTIONAL] Twitter OAuth 2.0 Client credentials.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn
# [OPTIONAL] LinkedIn OAuth 2.0 Client credentials.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok
# [OPTIONAL] TikTok app credentials.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google (Google Sign-In + Google Business Profile + YouTube — one OAuth app)
# [OPTIONAL] Google OAuth 2.0 Client credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pinterest
# [OPTIONAL] Pinterest App credentials.
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=


# ─── Payments (Flutterwave) ──────────────────────────────────────────────────
# [REQUIRED for billing] Flutterwave public key (exposed to browser for inline checkout).
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=

# [REQUIRED for billing] Flutterwave secret key (server-only, never expose to client).
FLUTTERWAVE_SECRET_KEY=

# [REQUIRED for billing] Shared secret hash for verifying Flutterwave webhook signatures.
# Must match the value configured in your Flutterwave dashboard > Webhooks.
FLUTTERWAVE_WEBHOOK_SECRET=


# ─── Webhooks ─────────────────────────────────────────────────────────────────
# [REQUIRED] Token for verifying social platform webhook subscriptions (Meta, etc.).
# Must be at least 16 characters. Generate with: openssl rand -base64 24
WEBHOOK_VERIFY_TOKEN=

# [REQUIRED] Shared secret used by the web app to forward verified webhooks to the API.
# Must be at least 16 characters. Generate with: openssl rand -base64 24
WEBHOOK_FORWARD_SECRET=


# ─── Storage ──────────────────────────────────────────────────────────────────
# [REQUIRED] Storage driver: 'local' (ephemeral on Railway) or 'r2' (recommended for prod).
STORAGE_DRIVER=r2

# [REQUIRED if STORAGE_DRIVER=r2] Cloudflare R2 credentials.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=mymanager-prod
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.mymanager.com

# [OPTIONAL] Only used if STORAGE_DRIVER=local (not recommended for production).
# LOCAL_STORAGE_PATH=./uploads


# ─── Email ────────────────────────────────────────────────────────────────────
# [REQUIRED] Resend API key for transactional emails (verification, password reset, etc.).
RESEND_API_KEY=


# ─── AI Services ──────────────────────────────────────────────────────────────
# [OPTIONAL] Claude API key for AI captions, image analysis, content insights.
ANTHROPIC_API_KEY=

# [OPTIONAL] Replicate API key for Stable Diffusion AI image generation.
REPLICATE_API_KEY=

# [OPTIONAL] OpenAI API key — used for Whisper video auto-captions only.
OPENAI_API_KEY=


# ─── Self-Hosted Tools ───────────────────────────────────────────────────────
# [OPTIONAL] LanguageTool URL for grammar checking.
# Railway: deploy as a separate service, use private networking URL.
LANGUAGETOOL_URL=http://languagetool.railway.internal:8010


# ─── Analytics & Monitoring ──────────────────────────────────────────────────
# [OPTIONAL] Google Analytics 4 property ID for deep GA4 integration.
GOOGLE_ANALYTICS_PROPERTY_ID=

# [OPTIONAL] PostHog product analytics key.
POSTHOG_API_KEY=

# [REQUIRED] Sentry DSN for runtime error tracking across all apps.
SENTRY_DSN=

# [CI-ONLY] Sentry auth token for source map uploads during build.
SENTRY_AUTH_TOKEN=


# ─── Exchange Rates ──────────────────────────────────────────────────────────
# [OPTIONAL] Open Exchange Rates API key for currency conversion.
OPEN_EXCHANGE_RATES_API_KEY=


# ─── CI/CD Secrets (not runtime — set in GitHub Actions / CI only) ───────────
# [CI-ONLY] EAS CLI authentication for mobile builds.
EXPO_TOKEN=

# [CI-ONLY] Railway CLI authentication for API + Worker deployments.
RAILWAY_TOKEN=

# [CI-ONLY] Vercel CLI authentication for web deployments.
VERCEL_TOKEN=

# [CI-ONLY] Vercel organization and project IDs.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# [CI-ONLY] Container registry credentials for worker Docker images.
DOCKER_REGISTRY=
DOCKER_USERNAME=
DOCKER_PASSWORD=

# Security — REQUIRED in production
# Apple Sign-In OAuth (optional; required if Apple sign-in enabled)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

METRICS_TOKEN=                         # random 32+ bytes hex; required to access /metrics
OAUTH_REDIRECT_WHITELIST=              # comma-separated full https URLs allowed for Google OAuth callback
ENABLE_SWAGGER=                        # leave empty in production (set "true" only for temporary debugging)
